# ============================================================================
# AI Asset Studio — environment variables
# Copy to .env.local and fill in real values. NEVER commit real secrets.
# ============================================================================

# --- Database (Neon Postgres) ---------------------------------------------
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# Direct (non-pooled) connection used by Prisma Migrate. On Neon this is the
# "direct" connection. Locally you may set it equal to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- NextAuth.js -----------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Public URL of the deployment. Locally: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (NextAuth provider) -------------------------------------
# From Google Cloud Console > Credentials > OAuth client ID (Web application).
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stripe (test mode for development) ------------------------------------
# Secret key: sk_test_... (dashboard > Developers > API keys)
STRIPE_SECRET_KEY=""
# Webhook signing secret: whsec_... (dashboard > Developers > Webhooks, or
# `stripe listen` for local testing)
STRIPE_WEBHOOK_SECRET=""
# Recurring Price IDs (price_...) for each plan, created in the Stripe dashboard.
STRIPE_PRICE_BASIC=""   # $9 / month
STRIPE_PRICE_PRO=""     # $19 / month

# --- ComfyUI (image generation backend) ------------------------------------
# Base URL of your running ComfyUI instance. Default local install:
COMFYUI_API_URL="http://localhost:8188"

# --- n8n automation webhook ------------------------------------------------
# Shared secret. n8n must send it as the `x-n8n-secret` header when calling
# POST /api/n8n/publish. Generate any long random string.
N8N_WEBHOOK_SECRET=""

# --- Google AdSense --------------------------------------------------------
# Publisher client id, e.g. ca-pub-XXXXXXXXXXXXXXXX. Leave empty to render
# labeled ad placeholders instead of live ads.
NEXT_PUBLIC_ADSENSE_CLIENT=""

# --- App ------------------------------------------------------------------
# Public base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
